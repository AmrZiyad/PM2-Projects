# Get input from the user
num = int(input("Enter a number: "))
count = 0

# Ensure the logic works for negative numbers
n = abs(num)

# Special case for 0
if n == 0:
    count = 1
else:
    # Use a while loop to count digits
    while n > 0:
        n //= 10  # Remove the last digit
        count += 1

print(f"Total digits: {count}")
